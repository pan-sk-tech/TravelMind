# Qwen/DashScope OpenAI-compatible LLM config
LLM_MODEL_ID=qwen-plus
LLM_API_KEY=your_dashscope_api_key_here
LLM_BASE_URL=
LLM_TIMEOUT=180
TRAVELMIND_DEMO_MODE=true

# Server
HOST=0.0.0.0
PORT=7000

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Logging
LOG_LEVEL=INFO

# Optional Unsplash credentials
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=

# AMap Web Service API key
AMAP_API_KEY=